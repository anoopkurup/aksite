  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^3.4.0",
    "tsup": "^8",
    "typescript": "^5"
